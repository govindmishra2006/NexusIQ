<file path="frontend/src/components/ProductPieChart.jsx">
import {

    ResponsiveContainer,
    PieChart,
    Pie,
    Tooltip

} from "recharts"

function ProductPieChart({ data }) {

    return (

        <div className="bg-slate-900 rounded-2xl p-8 shadow-lg">

            <h2 className="text-3xl font-bold mb-6">

                Product Distribution

            </h2>

            <ResponsiveContainer
                width="100%"
                height={300}
            >

                <PieChart>

                    <Pie

                        data={data}

                        dataKey="value"

                        nameKey="name"

                        outerRadius={100}

                    />

                    <Tooltip/>

                </PieChart>

            </ResponsiveContainer>

        </div>

    )

}

export default ProductPieChart
</file>

